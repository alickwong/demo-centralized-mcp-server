# Okta OIDC Configuration
OKTA_DOMAIN=dev-12345678.okta.com
OKTA_CLIENT_ID=your-okta-client-id
OKTA_CLIENT_SECRET=your-okta-client-secret

# AWS Configuration
AWS_REGION=us-west-2

# Demo Users (created in Okta)
ALICE_USERNAME=alice@yourdomain.com
ALICE_PASSWORD=alice-password
BOB_USERNAME=bob@yourdomain.com
BOB_PASSWORD=bob-password

# Contextual Demo User (Cedar input constraint demo)
# This user gets restricted ClaimsData access — only claims <= CONTEXTUAL_MAX_AMOUNT
CONTEXTUAL_USER=your-contextual-user@yourdomain.com
CONTEXTUAL_MAX_AMOUNT=100000
